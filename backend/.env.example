# Application Environment
# Options: development, production
ENVIRONMENT=development

# API Security Configuration
# Comma-separated list of allowed origins (CORS)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Comma-separated list of allowed hosts
ALLOWED_HOSTS=localhost,127.0.0.1,asleep-august-immature.ngrok-free.dev

# ==========================================
# AI Service Configuration
# ==========================================

# --- Gemini API Key ---
# 1. Go to Google AI Studio: https://aistudio.google.com/app/apikey
# 2. Sign in with your Google account
# 3. Click "Create API key"
# 4. Copy the generated key and paste it below
GEMINI_API_KEY=your_gemini_api_key_here

# --- Anthropic API Key ---
# 1. Go to Anthropic Console: https://console.anthropic.com/
# 2. Sign in or create an account
# 3. Navigate to "API Keys" in the dashboard
# 4. Click "Create Key", name it, and copy the key
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- OpenAI API Key ---
# 1. Go to OpenAI Platform: https://platform.openai.com/api-keys
# 2. Sign in to your account
# 3. Click "Create new secret key"
# 4. Copy the key (it won't be shown again) and paste it below
OPENAI_API_KEY=your_openai_api_key_here

# ==========================================
# Local AI Configuration
# ==========================================

# Ollama Configuration (for local model inference)
# 1. Download and install Ollama from https://ollama.com/
# 2. Run a model locally (e.g., `ollama run llama3`)
# 3. The default API URL is usually http://localhost:11434
# Format: http://host:port
OLLAMA_URL=http://localhost:11434

# ==========================================
# Gmail Integration
# ==========================================

# Google OAuth2 Credentials
# 1. Go to Google Cloud Console: https://console.cloud.google.com/
# 2. Create a new project (or select an existing one)
# 3. Go to "APIs & Services" > "Library" and enable the "Gmail API"
# 4. Go to "APIs & Services" > "OAuth consent screen" and configure it
# 5. Go to "APIs & Services" > "Credentials"
# 6. Click "Create Credentials" > "OAuth client ID"
# 7. Select "Web application" as the Application type
# 8. Add `http://localhost:8000/api/gmail/callback` under "Authorized redirect URIs"
# 9. Click "Create" and copy your Client ID and Client Secret below
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Redirect URI must match the one configured in Google Cloud Console
GMAIL_REDIRECT_URI=http://localhost:8000/api/gmail/callback
FRONTEND_URL=http://localhost:5173

# ==========================================
# Job Search (Command Center)
# ==========================================

# RapidAPI Key — powers the JSearch API (LinkedIn/Dice/Indeed/ZipRecruiter aggregation),
# the primary job-search source for Command Center. Without this, job search silently
# falls back to lower-quality DuckDuckGo scraping.
# 1. Go to https://rapidapi.com/ and sign in
# 2. Subscribe to the "JSearch" API (free tier available)
# 3. Copy your RapidAPI key from the app's dashboard
RAPIDAPI_KEY=your_rapidapi_key_here

# ==========================================
# Telegram Bot Integration
# ==========================================

# Telegram Bot Token
# 1. Open Telegram and search for the "@BotFather" bot
# 2. Start a chat and send the command: /newbot
# 3. Follow the prompts to choose a name and username for your bot
# 4. BotFather will give you an access token. Copy it below.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ==========================================
# System Configuration
# ==========================================

# Debug Mode (only set to true in development)
DEBUG=false

# Logging
LOG_LEVEL=INFO

# Security: Session configuration
SESSION_LIFETIME_HOURS=24
