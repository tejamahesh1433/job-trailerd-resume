# Application Environment
# Options: development, production
ENVIRONMENT=development

# API Security Configuration
# Comma-separated list of allowed origins (CORS)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Comma-separated list of allowed hosts
ALLOWED_HOSTS=localhost,127.0.0.1

# AI Service Configuration
# Required: Get from https://ai.google.dev
GEMINI_API_KEY=your_gemini_api_key_here

# Ollama Configuration (for local model inference)
# Format: http://host:port
# When running locally: http://localhost:11434
# When running in Docker: http://host.docker.internal:11434
OLLAMA_URL=http://localhost:11434

# OpenAI Configuration (for mail draft generation)
OPENAI_API_KEY=your_openai_api_key_here

# Gmail Integration (for saving drafts to Gmail)
# Get these from Google Cloud Console: https://console.cloud.google.com/apis/credentials
# 1. Create a project → Enable "Gmail API"
# 2. Create OAuth 2.0 Client ID (Web application)
# 3. Add http://localhost:8000/api/gmail/callback as Authorized redirect URI
GOOGLE_CLIENT_ID=your_client_id_here
GOOGLE_CLIENT_SECRET=your_client_secret_here
GMAIL_REDIRECT_URI=http://localhost:8000/api/gmail/callback
FRONTEND_URL=http://localhost:5173

# WhatsApp Integration (Twilio)
# Get from https://console.twilio.com
# 1. Sign up at twilio.com → Get Account SID and Auth Token from dashboard
# 2. Go to Messaging → Try WhatsApp → Join sandbox (send "join <word>" to the sandbox number)
# 3. Set webhook URL to: https://your-domain/api/whatsapp-webhook (use ngrok for local dev)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Format: +14155238886 (Twilio sandbox number, or your WhatsApp Business number)
TWILIO_WHATSAPP_NUMBER=

# Debug Mode (only set to true in development)
DEBUG=false

# Logging
LOG_LEVEL=INFO

# Security: Session configuration
SESSION_LIFETIME_HOURS=24
